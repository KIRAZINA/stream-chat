# Stream Chat - Environment Configuration
# Copy this file to .env and fill in the values

# ==========================================
# Application Settings
# ==========================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ==========================================
# Database (PostgreSQL)
# ==========================================
DATABASE_URL=jdbc:postgresql://postgres:5432/stream_chat_db
DATABASE_USERNAME=stream_chat_user
DATABASE_PASSWORD=CHANGE_ME_strong_password_here

# ==========================================
# Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# JWT Authentication
# ==========================================
# Must be at least 64 characters long
JWT_SECRET=CHANGE_ME_this_must_be_a_very_long_random_secret_key_of_at_least_64_characters_for_HMAC_SHA256_signing
JWT_EXPIRATION=86400000

# ==========================================
# CORS (comma-separated origins)
# ==========================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# Chat Settings
# ==========================================
CHAT_RETENTION_DAYS=90

# ==========================================
# AutoMod Configuration
# ==========================================
AUTOMOD_CAPS_THRESHOLD=0.7
AUTOMOD_SPAM_SCORE_THRESHOLD=3
AUTOMOD_TRUST_DECAY_RATE=0.1
AUTOMOD_SHADOW_BAN_ENABLED=true

# ==========================================
# Logging
# ==========================================
# Set to 'JSON' for production structured logging
LOG_FORMAT=TEXT
